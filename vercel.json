{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/data/(.*)", "destination": "/api/sanctions-data?file=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
